# =============================================================================
# OrionOps Environment Configuration
# Copy this file to .env for local development:
#   cp .env.example .env
#
# All values below work out-of-the-box with: docker compose up --build
# Replace values marked "changeme" only if you need external integrations.
# =============================================================================

# --- Backend (Java Spring Boot) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orionops
SPRING_DATASOURCE_USERNAME=orionops
SPRING_DATASOURCE_PASSWORD=orionops_dev
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=orionops

# --- Keycloak ---
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=orionops
KEYCLOAK_CLIENT_ID=orionops-api
KEYCLOAK_CLIENT_SECRET=changeme

# --- OPA ---
OPA_URL=http://localhost:8181

# --- Stripe ---
STRIPE_API_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=orionops-api

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8000

# --- Email (SMTP/IMAP) ---
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=orionops@example.com
SPRING_MAIL_PASSWORD=changeme
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
ORIONOPS_IMAP_HOST=imap.example.com
ORIONOPS_IMAP_PORT=993
ORIONOPS_IMAP_USERNAME=orionops@example.com
ORIONOPS_IMAP_PASSWORD=changeme

# --- Microsoft Entra ID Integration ---
ENTRA_ID_TENANT_ID=changeme
ENTRA_ID_CLIENT_ID=changeme
ENTRA_ID_CLIENT_SECRET=changeme
ENTRA_ID_GRAPH_URL=https://graph.microsoft.com

# --- Slack Integration ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/changeme

# --- Microsoft Teams Integration ---
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/changeme

# --- Monitoring Integration ---
MONITORING_ALERT_WEBHOOK_SECRET=changeme

# --- ClickHouse (OLAP) ---
CLICKHOUSE_URL=jdbc:clickhouse://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DATABASE=orionops_analytics

# --- Debezium CDC ---
DEBEZIUM_CONNECTOR_URL=http://localhost:8083

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8081
NEXT_PUBLIC_KEYCLOAK_REALM=orionops
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=orionops-web

# --- Mobile ---
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8081
EXPO_PUBLIC_KEYCLOAK_REALM=orionops
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=orionops-mobile
